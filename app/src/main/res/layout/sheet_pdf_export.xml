<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layout_pdf_export_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_source_sheet"
    android:orientation="vertical"
    android:paddingStart="@dimen/source_sheet_horizontal_padding"
    android:paddingTop="@dimen/source_sheet_top_padding"
    android:paddingEnd="@dimen/source_sheet_horizontal_padding"
    android:paddingBottom="@dimen/source_sheet_bottom_padding">

    <View
        android:layout_width="@dimen/source_sheet_drag_indicator_width"
        android:layout_height="@dimen/source_sheet_drag_indicator_height"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_source_sheet_drag_indicator"
        android:importantForAccessibility="no" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/editor_toolbar_height"
        android:layout_marginTop="@dimen/content_spacing_small">

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:text="@string/pdf_export_title"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/button_pdf_export_close"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/button_pdf_export_close"
            android:layout_width="@dimen/touch_target"
            android:layout_height="@dimen/touch_target"
            android:background="@drawable/bg_icon_button_round"
            android:contentDescription="@string/action_close_pdf_export_content_description"
            android:padding="@dimen/editor_overlay_button_padding"
            android:src="@drawable/ic_action_close_24"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/colorOnSurface" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_pdf_export_file_name"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_spacing_small"
                android:hint="@string/pdf_export_file_name_label"
                app:endIconContentDescription="@string/action_clear_pdf_name_content_description"
                app:endIconMode="clear_text"
                app:helperText="@string/pdf_export_file_name_helper"
                app:suffixText="@string/pdf_file_extension">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_pdf_export_file_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences|textNoSuggestions"
                    android:maxLength="96"
                    android:maxLines="1"
                    android:scrollHorizontally="true"
                    android:singleLine="true" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/pdf_export_section_spacing"
                android:text="@string/pdf_export_quality_label"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/group_pdf_export_quality"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_spacing_small"
                android:contentDescription="@string/action_select_pdf_quality_content_description"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_pdf_quality_compact"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/touch_target"
                    android:layout_weight="1"
                    android:contentDescription="@string/action_select_pdf_quality_compact_content_description"
                    android:ellipsize="end"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:maxLines="1"
                    android:minWidth="0dp"
                    android:paddingStart="@dimen/pdf_export_chip_horizontal_padding"
                    android:paddingEnd="@dimen/pdf_export_chip_horizontal_padding"
                    android:text="@string/pdf_quality_compact"
                    android:textAllCaps="false"
                    android:textSize="@dimen/pdf_export_chip_text_size" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_pdf_quality_balanced"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/touch_target"
                    android:layout_weight="1"
                    android:contentDescription="@string/action_select_pdf_quality_balanced_content_description"
                    android:ellipsize="end"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:maxLines="1"
                    android:minWidth="0dp"
                    android:paddingStart="@dimen/pdf_export_chip_horizontal_padding"
                    android:paddingEnd="@dimen/pdf_export_chip_horizontal_padding"
                    android:text="@string/pdf_quality_balanced_short"
                    android:textAllCaps="false"
                    android:textSize="@dimen/pdf_export_chip_text_size" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_pdf_quality_high"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/touch_target"
                    android:layout_weight="1"
                    android:contentDescription="@string/action_select_pdf_quality_high_content_description"
                    android:ellipsize="end"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:maxLines="1"
                    android:minWidth="0dp"
                    android:paddingStart="@dimen/pdf_export_chip_horizontal_padding"
                    android:paddingEnd="@dimen/pdf_export_chip_horizontal_padding"
                    android:text="@string/pdf_quality_high_short"
                    android:textAllCaps="false"
                    android:textSize="@dimen/pdf_export_chip_text_size" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <TextView
                android:id="@+id/text_pdf_quality_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_spacing_small"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="Хорошая читаемость и умеренный размер" />

            <LinearLayout
                android:id="@+id/row_pdf_export_additional"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/pdf_export_section_spacing"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:minHeight="@dimen/pdf_export_setting_row_height"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="0dp"
                    android:paddingEnd="@dimen/content_spacing_small">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/pdf_export_additional_parameters"
                        android:textAppearance="?attr/textAppearanceTitleSmall"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/text_pdf_export_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/pdf_export_summary_spacing"
                        android:maxLines="2"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="По изображению · Авто · Стандартные поля" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/image_pdf_export_additional_chevron"
                    android:layout_width="@dimen/editor_action_icon_size"
                    android:layout_height="@dimen/editor_action_icon_size"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_action_chevron_right_24"
                    app:tint="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_pdf_export_additional_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:id="@+id/row_pdf_export_page_size"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/pdf_export_setting_row_height"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/pdf_page_size_label"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/text_pdf_export_page_size_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/content_spacing_small"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="По изображению" />

                    <ImageView
                        android:layout_width="@dimen/editor_action_icon_size"
                        android:layout_height="@dimen/editor_action_icon_size"
                        android:layout_marginStart="@dimen/pdf_export_summary_spacing"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_action_chevron_right_24"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/row_pdf_export_orientation"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/pdf_export_setting_row_height"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/pdf_export_orientation_label"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/text_pdf_export_orientation_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/content_spacing_small"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="Автоматически" />

                    <ImageView
                        android:layout_width="@dimen/editor_action_icon_size"
                        android:layout_height="@dimen/editor_action_icon_size"
                        android:layout_marginStart="@dimen/pdf_export_summary_spacing"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_action_chevron_right_24"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/row_pdf_export_margins"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/pdf_export_setting_row_height"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/pdf_margin_label"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/text_pdf_export_margins_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/content_spacing_small"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="Стандартные" />

                    <ImageView
                        android:layout_width="@dimen/editor_action_icon_size"
                        android:layout_height="@dimen/editor_action_icon_size"
                        android:layout_marginStart="@dimen/pdf_export_summary_spacing"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_action_chevron_right_24"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_pdf_export_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_spacing_small"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/text_pdf_export_location"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:maxLines="2"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    tools:text="Сохранение: Загрузки" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_pdf_export_change_location"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/touch_target"
                    android:layout_marginStart="@dimen/content_spacing_small"
                    android:contentDescription="@string/action_change_pdf_location_content_description"
                    android:minWidth="0dp"
                    android:text="@string/action_change_pdf_location" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/button_pdf_export_convert"
        android:layout_width="match_parent"
        android:layout_height="@dimen/primary_button_height"
        android:layout_marginTop="@dimen/pdf_export_section_spacing"
        android:background="@drawable/bg_primary_action"
        android:contentDescription="@string/action_convert_pdf_content_description"
        android:drawableStart="@drawable/ic_action_create_pdf_24"
        android:drawablePadding="@dimen/content_spacing_small"
        android:drawableTint="@color/primary_action_content"
        android:gravity="center"
        android:text="@string/action_convert_pdf"
        android:textAllCaps="false"
        android:textColor="@color/primary_action_content"
        android:textStyle="bold" />
</LinearLayout>
