<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_source_sheet"
    android:orientation="vertical"
    android:paddingStart="@dimen/source_sheet_horizontal_padding"
    android:paddingTop="@dimen/source_sheet_top_padding"
    android:paddingEnd="@dimen/source_sheet_horizontal_padding"
    android:paddingBottom="@dimen/source_sheet_bottom_padding">

    <View
        android:layout_width="@dimen/source_sheet_drag_indicator_width"
        android:layout_height="@dimen/source_sheet_drag_indicator_height"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_source_sheet_drag_indicator"
        android:importantForAccessibility="no" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/editor_toolbar_height"
        android:layout_marginTop="@dimen/content_spacing_small">

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:text="@string/pdf_export_title"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/button_pdf_export_close"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/button_pdf_export_close"
            android:layout_width="@dimen/touch_target"
            android:layout_height="@dimen/touch_target"
            android:background="@drawable/bg_icon_button_round"
            android:contentDescription="@string/action_close_pdf_export_content_description"
            android:padding="@dimen/editor_overlay_button_padding"
            android:src="@drawable/ic_action_close_24"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/colorOnSurface" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/content_spacing_medium">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_pdf_export_file_name"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_spacing_small"
                android:hint="@string/pdf_export_file_name_label"
                app:endIconContentDescription="@string/action_clear_pdf_name_content_description"
                app:endIconMode="clear_text"
                app:helperText="@string/pdf_export_file_name_helper">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_pdf_export_file_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences"
                    android:maxLength="120"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/pdf_export_section_spacing"
                android:text="@string/pdf_export_quality_label"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/group_pdf_export_quality"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:contentDescription="@string/action_select_pdf_quality_content_description"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/radio_pdf_quality_compact"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/pdf_quality_compact" />

                <RadioButton
                    android:id="@+id/radio_pdf_quality_balanced"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/pdf_quality_balanced" />

                <RadioButton
                    android:id="@+id/radio_pdf_quality_high"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/pdf_quality_high" />
            </RadioGroup>

            <TextView
                android:id="@+id/text_pdf_quality_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/pdf_export_section_spacing"
                android:text="@string/pdf_page_size_label"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/group_pdf_export_page_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:contentDescription="@string/action_select_pdf_page_size_content_description"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/radio_pdf_page_a4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/pdf_page_size_a4" />

                <RadioButton
                    android:id="@+id/radio_pdf_page_image"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/pdf_page_size_image" />
            </RadioGroup>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/pdf_export_section_spacing"
                android:text="@string/pdf_export_orientation_label"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/group_pdf_export_orientation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:contentDescription="@string/action_select_pdf_orientation_content_description"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/radio_pdf_orientation_auto"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/pdf_orientation_auto" />

                <RadioButton
                    android:id="@+id/radio_pdf_orientation_portrait"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/pdf_orientation_portrait" />

                <RadioButton
                    android:id="@+id/radio_pdf_orientation_landscape"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/pdf_orientation_landscape" />
            </RadioGroup>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/pdf_export_section_spacing"
                android:text="@string/pdf_margin_label"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/group_pdf_export_margins"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:contentDescription="@string/action_select_pdf_margins_content_description"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/radio_pdf_margin_none"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/pdf_margin_none" />

                <RadioButton
                    android:id="@+id/radio_pdf_margin_small"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/pdf_margin_small" />

                <RadioButton
                    android:id="@+id/radio_pdf_margin_standard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/pdf_margin_standard" />
            </RadioGroup>

            <TextView
                android:id="@+id/text_pdf_export_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/pdf_export_section_spacing"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/content_spacing_small"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_pdf_export_browse"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="@dimen/editor_bottom_button_height"
            android:layout_weight="1"
            android:contentDescription="@string/action_browse_pdf_location_content_description"
            android:text="@string/action_browse_pdf_location"
            app:icon="@drawable/ic_source_files_24" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_pdf_export_convert"
            android:layout_width="0dp"
            android:layout_height="@dimen/editor_bottom_button_height"
            android:layout_marginStart="@dimen/content_spacing_small"
            android:layout_weight="2"
            android:contentDescription="@string/action_convert_pdf_content_description"
            android:text="@string/action_convert_pdf"
            app:icon="@drawable/ic_action_create_pdf_24" />
    </LinearLayout>
</LinearLayout>
