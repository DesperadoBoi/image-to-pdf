<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_content_padding"
        android:paddingTop="@dimen/screen_content_padding"
        android:paddingEnd="@dimen/screen_content_padding"
        android:paddingBottom="@dimen/screen_content_padding">

        <TextView
            android:id="@+id/text_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/app_name"
            android:textAppearance="?attr/textAppearanceHeadlineMedium" />

        <TextView
            android:id="@+id/text_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_spacing_small"
            android:gravity="center"
            android:text="@string/main_description"
            android:textAppearance="?attr/textAppearanceBodyLarge" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_select_images"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_spacing_large"
            android:text="@string/action_select_images" />

        <TextView
            android:id="@+id/text_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_spacing_medium"
            android:gravity="center"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            tools:text="Изображения не выбраны" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_create_pdf"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_spacing_medium"
            android:enabled="false"
            android:text="@string/action_create_pdf" />

        <ProgressBar
            android:id="@+id/progress_generation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_spacing_medium"
            android:visibility="gone" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
