<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="@dimen/screen_content_padding"
    android:paddingTop="@dimen/screen_content_padding"
    android:paddingEnd="@dimen/screen_content_padding"
    android:paddingBottom="@dimen/screen_content_padding"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/text_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/app_name"
        android:textAppearance="?attr/textAppearanceHeadlineMedium" />

    <TextView
        android:id="@+id/text_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/content_spacing_small"
        android:gravity="center"
        android:text="@string/main_description"
        android:textAppearance="?attr/textAppearanceBodyLarge" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_select_images"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/content_spacing_large"
        android:text="@string/action_select_images" />

    <TextView
        android:id="@+id/text_selection_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/content_spacing_medium"
        android:gravity="center"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        tools:text="Изображения не выбраны" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_pages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/content_spacing_medium"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:visibility="gone"
        tools:itemCount="3"
        tools:listitem="@layout/item_page" />

    <LinearLayout
        android:id="@+id/layout_pdf_settings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/content_spacing_medium"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_pdf_settings_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pdf_settings_title"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <LinearLayout
            android:id="@+id/layout_pdf_page_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/pdf_options_row_spacing"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/text_pdf_page_size_label"
                android:layout_width="@dimen/pdf_options_label_width"
                android:layout_height="wrap_content"
                android:labelFor="@id/spinner_pdf_page_size"
                android:text="@string/pdf_page_size_label"
                android:textAppearance="?attr/textAppearanceBodyMedium" />

            <Spinner
                android:id="@+id/spinner_pdf_page_size"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:contentDescription="@string/pdf_page_size_content_description"
                android:entries="@array/pdf_page_size_options" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_pdf_image_placement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/pdf_options_row_spacing"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/text_pdf_image_placement_label"
                android:layout_width="@dimen/pdf_options_label_width"
                android:layout_height="wrap_content"
                android:labelFor="@id/spinner_pdf_image_placement"
                android:text="@string/pdf_image_placement_label"
                android:textAppearance="?attr/textAppearanceBodyMedium" />

            <Spinner
                android:id="@+id/spinner_pdf_image_placement"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:contentDescription="@string/pdf_image_placement_content_description"
                android:entries="@array/pdf_image_placement_options" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_pdf_margin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/pdf_options_row_spacing"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/text_pdf_margin_label"
                android:layout_width="@dimen/pdf_options_label_width"
                android:layout_height="wrap_content"
                android:labelFor="@id/spinner_pdf_margin"
                android:text="@string/pdf_margin_label"
                android:textAppearance="?attr/textAppearanceBodyMedium" />

            <Spinner
                android:id="@+id/spinner_pdf_margin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:contentDescription="@string/pdf_margin_content_description"
                android:entries="@array/pdf_margin_options" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/text_operation_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/content_spacing_small"
        android:gravity="center"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        tools:text="PDF успешно создан" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_create_pdf"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/content_spacing_medium"
        android:enabled="false"
        android:text="@string/action_create_pdf" />

    <LinearLayout
        android:id="@+id/layout_pdf_result"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/content_spacing_medium"
        android:orientation="vertical"
        android:padding="@dimen/pdf_result_block_padding"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/text_pdf_result_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            tools:text="ImageToPDF_20260720_120000.pdf" />

        <TextView
            android:id="@+id/text_pdf_result_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/pdf_result_details_spacing"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            tools:text="3 pages, 1.4 MB" />

        <LinearLayout
            android:id="@+id/layout_pdf_result_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/pdf_result_actions_spacing"
            android:orientation="vertical">

            <Button
                android:id="@+id/button_open_pdf"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/action_open_pdf" />

            <Button
                android:id="@+id/button_share_pdf"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/pdf_result_action_button_spacing"
                android:text="@string/action_share_pdf" />

            <Button
                android:id="@+id/button_new_document"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/pdf_result_action_button_spacing"
                android:text="@string/action_new_document" />
        </LinearLayout>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progress_generation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/content_spacing_medium"
        android:visibility="gone" />

</LinearLayout>
