<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/document_viewer_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/viewer_toolbar_height"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/screen_horizontal_padding">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_viewer_back"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="@dimen/touch_target"
            android:layout_height="@dimen/touch_target"
            android:contentDescription="@string/viewer_back_content_description"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="@dimen/touch_target"
            android:padding="0dp"
            app:icon="@drawable/ic_action_back_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/text_viewer_title"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="@dimen/content_spacing_small"
            android:layout_weight="1"
            android:ellipsize="middle"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:text="@string/viewer_title_default"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_viewer_share"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="@dimen/touch_target"
            android:layout_height="@dimen/touch_target"
            android:contentDescription="@string/viewer_share_content_description"
            android:enabled="false"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="@dimen/touch_target"
            android:padding="0dp"
            app:icon="@drawable/ic_action_share_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="?attr/colorOnSurface" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_viewer_more"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="@dimen/touch_target"
            android:layout_height="@dimen/touch_target"
            android:contentDescription="@string/viewer_more_content_description"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="@dimen/touch_target"
            android:padding="0dp"
            app:icon="@drawable/ic_action_more_vert_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="?attr/colorOnSurface" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/state_viewer_loading"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?android:attr/colorBackground"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/content_spacing_large">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/viewer_loading_content_description"
                android:indeterminate="true" />

            <TextView
                android:id="@+id/text_viewer_loading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_spacing_medium"
                android:gravity="center"
                android:text="@string/viewer_loading_opening"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="?attr/colorOnSurface" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/state_viewer_error"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/content_spacing_large"
            android:visibility="gone">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_broken_image_24"
                app:tint="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/text_viewer_error_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_spacing_medium"
                android:gravity="center"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_viewer_error_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_spacing_small"
                android:gravity="center"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/content_viewer_pdf"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <com.desperadoboi.imagetopdf.ui.editor.ZoomableImageView
                android:id="@+id/image_viewer_pdf_page"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_margin="@dimen/viewer_content_margin"
                android:layout_weight="1"
                android:background="@color/editor_preview_background"
                android:contentDescription="@string/viewer_pdf_page_content_description" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="@dimen/viewer_controls_padding">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_viewer_previous_page"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/touch_target"
                    android:minWidth="@dimen/touch_target"
                    android:text="@string/viewer_previous_page" />

                <TextView
                    android:id="@+id/text_viewer_page_counter"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/touch_target"
                    android:layout_marginHorizontal="@dimen/content_spacing_small"
                    android:gravity="center"
                    android:minWidth="88dp"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="?attr/colorOnSurface" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_viewer_next_page"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/touch_target"
                    android:minWidth="@dimen/touch_target"
                    android:text="@string/viewer_next_page" />
            </LinearLayout>
        </LinearLayout>

        <com.desperadoboi.imagetopdf.ui.editor.ZoomableImageView
            android:id="@+id/content_viewer_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/colorSurfaceVariant"
            android:contentDescription="@string/viewer_image_content_description"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/content_viewer_text"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:contentDescription="@string/viewer_text_content_description"
            android:paddingBottom="@dimen/content_spacing_large"
            android:visibility="gone" />

        <HorizontalScrollView
            android:id="@+id/content_viewer_spreadsheet"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="horizontal"
            android:visibility="gone">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_viewer_spreadsheet"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:contentDescription="@string/viewer_table_content_description" />
        </HorizontalScrollView>

        <TextView
            android:id="@+id/text_viewer_notice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="?attr/colorPrimaryContainer"
            android:gravity="center"
            android:padding="@dimen/content_spacing_small"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:visibility="gone" />
    </FrameLayout>

</LinearLayout>
