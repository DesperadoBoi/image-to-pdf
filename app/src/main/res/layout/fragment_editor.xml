<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <ImageButton
        android:id="@+id/button_back"
        android:layout_width="@dimen/touch_target"
        android:layout_height="@dimen/editor_toolbar_height"
        android:background="@drawable/bg_icon_button_round"
        android:contentDescription="@string/action_editor_back_content_description"
        android:padding="@dimen/editor_overlay_button_padding"
        android:src="@drawable/ic_action_back_24"
        app:tint="?attr/colorOnSurface"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/text_editor_title"
        android:layout_width="0dp"
        android:layout_height="@dimen/editor_toolbar_height"
        android:layout_marginStart="@dimen/content_spacing_small"
        android:layout_marginEnd="@dimen/content_spacing_small"
        android:gravity="center_vertical"
        android:text="@string/editor_title"
        android:textAppearance="?attr/textAppearanceTitleLarge"
        android:textColor="?attr/colorOnSurface"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/button_add_images"
        app:layout_constraintStart_toEndOf="@id/button_back"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_add_images"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/editor_toolbar_height"
        android:contentDescription="@string/action_add_page_content_description"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:minWidth="0dp"
        android:text="@string/action_add"
        app:icon="@drawable/ic_action_add_24"
        app:iconGravity="textStart"
        app:iconPadding="@dimen/editor_compact_icon_spacing"
        app:iconTint="?attr/colorPrimary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/text_selection_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/content_spacing_medium"
        android:gravity="center"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?attr/colorOnSurface"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_editor_title"
        tools:text="Выбрано 3 изображения" />

    <TextView
        android:id="@+id/text_reorder_hint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/editor_hint_spacing"
        android:gravity="center"
        android:text="@string/reorder_hint"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="?attr/colorOnSurfaceVariant"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_selection_status" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_pages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/content_spacing_medium"
        android:layout_marginBottom="@dimen/content_spacing_medium"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/page_item_spacing"
        app:layout_constraintBottom_toTopOf="@id/layout_editor_bottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_reorder_hint"
        tools:itemCount="4"
        tools:listitem="@layout/item_page" />

    <LinearLayout
        android:id="@+id/layout_editor_bottom"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="@dimen/bottom_action_padding"
        android:paddingBottom="@dimen/bottom_action_padding"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/layout_pdf_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/content_spacing_small"
            android:background="@drawable/bg_surface_panel"
            android:orientation="vertical"
            android:padding="@dimen/pdf_latest_result_padding"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/pdf_result_latest_title"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_latest_pdf_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/pdf_result_details_spacing"
                android:ellipsize="middle"
                android:maxLines="1"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurface"
                tools:text="ImageToPDF_20260721_041622.pdf" />

            <TextView
                android:id="@+id/text_latest_pdf_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/pdf_result_details_spacing"
                android:maxLines="1"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="5 стр. · 3,4 МБ" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/pdf_latest_result_action_spacing"
                android:gravity="end|center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_share_latest_pdf"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/touch_target"
                    android:contentDescription="@string/action_share_latest_pdf_content_description"
                    android:minWidth="0dp"
                    android:text="@string/action_share_pdf" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_open_pdf_result"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/touch_target"
                    android:layout_marginStart="@dimen/content_spacing_small"
                    android:contentDescription="@string/action_open_latest_pdf_content_description"
                    android:minWidth="0dp"
                    android:text="@string/action_open_pdf_short" />
            </LinearLayout>
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_create_pdf"
            android:layout_width="match_parent"
            android:layout_height="@dimen/primary_button_height"
            android:background="@drawable/bg_primary_action"
            android:contentDescription="@string/action_create_pdf"
            android:drawableStart="@drawable/ic_action_create_pdf_24"
            android:drawablePadding="@dimen/content_spacing_small"
            android:drawableTint="@color/primary_action_content"
            android:enabled="false"
            android:gravity="center"
            android:minHeight="@dimen/primary_button_height"
            android:text="@string/action_create_pdf"
            android:textAllCaps="false"
            android:textColor="@color/primary_action_content"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/progress_generation"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_spacing_small"
            android:indeterminate="false"
            android:visibility="gone" />

        <TextView
            android:id="@+id/text_generation_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/pdf_generation_progress_text_spacing"
            android:gravity="center"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurface"
            android:visibility="gone"
            tools:text="Создание PDF: 2 из 5"
            tools:visibility="visible" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_cancel_generation"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/pdf_generation_cancel_button_spacing"
            android:minHeight="@dimen/pdf_generation_cancel_button_min_height"
            android:text="@string/action_cancel_pdf_generation"
            android:visibility="gone"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/text_operation_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_spacing_small"
            android:gravity="center"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="gone"
            tools:text="PDF успешно создан" />

    </LinearLayout>

    <include
        android:id="@+id/banner_pdf_success"
        layout="@layout/view_pdf_success_banner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/content_spacing_small"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_editor_title" />

</androidx.constraintlayout.widget.ConstraintLayout>
