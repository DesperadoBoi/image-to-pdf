<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_back"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="@dimen/editor_top_button_min_width"
        android:text="@string/action_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/text_editor_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/content_spacing_small"
        android:layout_marginEnd="@dimen/content_spacing_small"
        android:gravity="center"
        android:text="@string/editor_title"
        android:textAppearance="?attr/textAppearanceTitleLarge"
        app:layout_constraintBottom_toBottomOf="@id/button_back"
        app:layout_constraintEnd_toStartOf="@id/button_add_images"
        app:layout_constraintStart_toEndOf="@id/button_back"
        app:layout_constraintTop_toTopOf="@id/button_back" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_add_images"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="@dimen/editor_top_button_min_width"
        android:text="@string/action_add"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/text_selection_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/content_spacing_medium"
        android:gravity="center"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_editor_title"
        tools:text="Выбрано 3 изображения" />

    <TextView
        android:id="@+id/text_reorder_hint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/content_spacing_small"
        android:gravity="center"
        android:text="@string/reorder_hint"
        android:textAppearance="?attr/textAppearanceBodySmall"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_selection_status" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_pages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/content_spacing_medium"
        android:layout_marginBottom="@dimen/content_spacing_medium"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/layout_editor_bottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_reorder_hint"
        tools:itemCount="4"
        tools:listitem="@layout/item_page" />

    <LinearLayout
        android:id="@+id/layout_editor_bottom"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_create_pdf"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:enabled="false"
            android:text="@string/action_create_pdf" />

        <ProgressBar
            android:id="@+id/progress_generation"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_spacing_small"
            android:indeterminate="false"
            android:visibility="gone" />

        <TextView
            android:id="@+id/text_generation_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/pdf_generation_progress_text_spacing"
            android:gravity="center"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:visibility="gone"
            tools:text="Создание PDF: 2 из 5"
            tools:visibility="visible" />

        <Button
            android:id="@+id/button_cancel_generation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/pdf_generation_cancel_button_spacing"
            android:minHeight="@dimen/pdf_generation_cancel_button_min_height"
            android:text="@string/action_cancel_pdf_generation"
            android:visibility="gone"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/text_operation_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_spacing_small"
            android:gravity="center"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            tools:text="PDF успешно создан" />

        <LinearLayout
            android:id="@+id/layout_pdf_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_spacing_medium"
            android:orientation="vertical"
            android:padding="@dimen/pdf_result_block_padding"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/text_pdf_result_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                tools:text="ImageToPDF_20260720_120000.pdf" />

            <TextView
                android:id="@+id/text_pdf_result_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/pdf_result_details_spacing"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                tools:text="3 pages, 1.4 MB" />

            <LinearLayout
                android:id="@+id/layout_pdf_result_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/pdf_result_actions_spacing"
                android:orientation="vertical">

                <Button
                    android:id="@+id/button_open_pdf"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/action_open_pdf" />

                <Button
                    android:id="@+id/button_share_pdf"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/pdf_result_action_button_spacing"
                    android:text="@string/action_share_pdf" />

                <Button
                    android:id="@+id/button_new_document"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/pdf_result_action_button_spacing"
                    android:text="@string/action_new_document" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
