<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:clickable="true"
    android:focusable="true">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_close_page_preview"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="@string/action_close_page_preview_content_description"
        android:minWidth="@dimen/preview_top_button_min_width"
        android:text="@string/action_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/text_page_preview_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/content_spacing_small"
        android:layout_marginEnd="@dimen/content_spacing_small"
        android:gravity="center"
        android:maxLines="1"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        app:layout_constraintBottom_toBottomOf="@id/button_close_page_preview"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/button_close_page_preview"
        app:layout_constraintTop_toTopOf="@id/button_close_page_preview"
        tools:text="3 из 7" />

    <FrameLayout
        android:id="@+id/layout_page_preview_image"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/content_spacing_medium"
        android:layout_marginBottom="@dimen/content_spacing_medium"
        android:background="?attr/colorSurfaceVariant"
        app:layout_constraintBottom_toTopOf="@id/layout_page_preview_bottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/button_close_page_preview">

        <com.desperadoboi.imagetopdf.ui.editor.ZoomableImageView
            android:id="@+id/image_page_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/page_preview_image_content_description_generic" />

        <ProgressBar
            android:id="@+id/progress_page_preview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/text_page_preview_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:padding="@dimen/preview_error_padding"
            android:text="@string/status_page_preview_load_error"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:visibility="gone"
            tools:visibility="visible" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/layout_page_preview_bottom"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_previous_page"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:contentDescription="@string/action_previous_page_content_description"
            android:minHeight="@dimen/preview_bottom_button_min_height"
            android:text="@string/action_previous_page" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_rotate_preview_page"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/content_spacing_small"
            android:layout_marginEnd="@dimen/content_spacing_small"
            android:layout_weight="1"
            android:contentDescription="@string/action_rotate_preview_page_content_description"
            android:minHeight="@dimen/preview_bottom_button_min_height"
            android:text="@string/action_rotate" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_next_page"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:contentDescription="@string/action_next_page_content_description"
            android:minHeight="@dimen/preview_bottom_button_min_height"
            android:text="@string/action_next_page" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
