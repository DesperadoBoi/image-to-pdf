<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="@dimen/gallery_grid_half_spacing">

    <FrameLayout
        android:id="@+id/layout_gallery_image"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_gallery_thumbnail"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/image_gallery_thumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:importantForAccessibility="no"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/text_gallery_selection_badge"
            android:layout_width="@dimen/gallery_selection_badge_size"
            android:layout_height="@dimen/gallery_selection_badge_size"
            android:layout_gravity="top|end"
            android:layout_margin="@dimen/gallery_selection_badge_margin"
            android:background="@drawable/bg_gallery_selection_badge"
            android:gravity="center"
            android:textColor="?attr/colorOnPrimary"
            android:textStyle="bold"
            android:visibility="gone" />
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
