<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <ImageButton
        android:id="@+id/button_about_back"
        android:layout_width="@dimen/touch_target"
        android:layout_height="@dimen/touch_target"
        android:background="@drawable/bg_icon_button_round"
        android:contentDescription="@string/action_about_back_content_description"
        android:padding="@dimen/editor_overlay_button_padding"
        android:src="@drawable/ic_action_back_24"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="?attr/colorOnSurface" />

    <TextView
        android:id="@+id/text_about_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/content_spacing_small"
        android:gravity="center_vertical"
        android:minHeight="@dimen/touch_target"
        android:text="@string/about_title"
        android:textAppearance="?attr/textAppearanceTitleLarge"
        android:textColor="?attr/colorOnSurface"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/button_about_back"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_about"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/content_spacing_medium"
        android:clipToPadding="false"
        android:fillViewport="false"
        android:paddingBottom="@dimen/content_spacing_large"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_about_title">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_panel"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/about_panel_padding">

                <ImageView
                    android:layout_width="@dimen/about_app_icon_size"
                    android:layout_height="@dimen/about_app_icon_size"
                    android:adjustViewBounds="true"
                    android:importantForAccessibility="no"
                    android:src="@mipmap/ic_launcher" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/content_spacing_medium"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name"
                        android:textAppearance="?attr/textAppearanceHeadlineSmall"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/text_about_version"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/content_spacing_small"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="Версия 1.0.0" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_spacing_large"
                android:text="@string/about_description"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="?attr/colorOnSurface" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_spacing_medium"
                android:background="@drawable/bg_surface_panel"
                android:orientation="vertical"
                android:padding="@dimen/about_panel_padding">

                <androidx.appcompat.widget.AppCompatTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawablePadding="@dimen/content_spacing_small"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/touch_target"
                    android:text="@string/about_device_processing"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:textColor="?attr/colorOnSurface"
                    app:drawableStartCompat="@drawable/ic_action_check_circle_24"
                    app:drawableTint="?attr/colorPrimary" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawablePadding="@dimen/content_spacing_small"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/touch_target"
                    android:text="@string/about_no_ads"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:textColor="?attr/colorOnSurface"
                    app:drawableStartCompat="@drawable/ic_action_check_circle_24"
                    app:drawableTint="?attr/colorPrimary" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawablePadding="@dimen/content_spacing_small"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/touch_target"
                    android:text="@string/about_no_registration"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:textColor="?attr/colorOnSurface"
                    app:drawableStartCompat="@drawable/ic_action_check_circle_24"
                    app:drawableTint="?attr/colorPrimary" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_about_privacy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_spacing_large"
                android:contentDescription="@string/action_open_local_privacy_content_description"
                android:maxLines="2"
                android:minHeight="@dimen/editor_bottom_button_height"
                android:text="@string/action_privacy_policy"
                android:textStyle="bold"
                app:icon="@drawable/ic_action_chevron_right_24"
                app:iconGravity="textEnd" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_about_email"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_spacing_small"
                android:contentDescription="@string/action_email_developer_content_description"
                android:maxLines="2"
                android:minHeight="@dimen/editor_bottom_button_height"
                android:text="@string/action_email_developer" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_about_privacy_browser"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_spacing_small"
                android:contentDescription="@string/action_open_privacy_browser_content_description"
                android:maxLines="2"
                android:minHeight="@dimen/touch_target"
                android:text="@string/action_open_privacy_browser"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/text_about_developer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_spacing_large"
                android:gravity="center"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="Разработчик: DesperadoBoi" />

            <TextView
                android:id="@+id/text_about_copyright"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/about_footer_spacing"
                android:gravity="center"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="© 2026 DesperadoBoi" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
