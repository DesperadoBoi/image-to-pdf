<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_all_tools_toolbar"
        android:layout_width="0dp"
        android:layout_height="@dimen/touch_target"
        android:background="?android:attr/colorBackground"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_all_tools_back"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="@dimen/touch_target"
            android:layout_height="@dimen/touch_target"
            android:contentDescription="@string/action_all_tools_back_content_description"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="@dimen/touch_target"
            android:padding="0dp"
            app:icon="@drawable/ic_action_back_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="?attr/colorOnSurface"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/text_all_tools_title"
            android:layout_width="0dp"
            android:layout_height="@dimen/touch_target"
            android:layout_marginStart="@dimen/content_spacing_small"
            android:gravity="center_vertical"
            android:text="@string/all_tools_title"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/button_all_tools_back"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/divider_all_tools_toolbar"
            android:layout_width="0dp"
            android:layout_height="@dimen/catalog_toolbar_divider_height"
            android:alpha="0.32"
            android:background="?attr/colorOutline"
            android:importantForAccessibility="no"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_all_tools"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:contentDescription="@string/all_tools_content_description"
        android:paddingBottom="@dimen/content_spacing_medium"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_all_tools_toolbar"
        tools:itemCount="12"
        tools:listitem="@layout/item_catalog_tool" />

</androidx.constraintlayout.widget.ConstraintLayout>
