<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <ImageButton
        android:id="@+id/button_privacy_back"
        android:layout_width="@dimen/touch_target"
        android:layout_height="@dimen/touch_target"
        android:background="@drawable/bg_icon_button_round"
        android:contentDescription="@string/action_privacy_back_content_description"
        android:padding="@dimen/editor_overlay_button_padding"
        android:src="@drawable/ic_action_back_24"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="?attr/colorOnSurface" />

    <TextView
        android:id="@+id/text_privacy_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/content_spacing_small"
        android:gravity="center_vertical"
        android:maxLines="2"
        android:minHeight="@dimen/touch_target"
        android:text="@string/privacy_policy_title"
        android:textAppearance="?attr/textAppearanceTitleLarge"
        android:textColor="?attr/colorOnSurface"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/button_privacy_back"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/content_spacing_medium"
        android:clipToPadding="false"
        android:fillViewport="false"
        android:paddingBottom="@dimen/content_spacing_large"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_privacy_title">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_panel"
                android:orientation="vertical"
                android:padding="@dimen/about_panel_padding">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/privacy_effective_date_label"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/about_metadata_value_spacing"
                    android:text="@string/privacy_effective_date"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/content_spacing_medium"
                    android:text="@string/privacy_developer_label"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/about_metadata_value_spacing"
                    android:text="@string/developer_name"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/content_spacing_medium"
                    android:text="@string/privacy_contact_email_label"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/about_metadata_value_spacing"
                    android:text="@string/developer_email"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:textColor="?attr/colorOnSurface"
                    android:textIsSelectable="true" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/content_spacing_medium"
                    android:text="@string/privacy_public_url_label"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/about_metadata_value_spacing"
                    android:breakStrategy="simple"
                    android:text="@string/privacy_policy_url"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurface"
                    android:textIsSelectable="true" />
            </LinearLayout>

            <TextView
                style="@style/PrivacyPolicySectionTitle"
                android:text="@string/privacy_scope_title" />

            <TextView
                style="@style/PrivacyPolicySectionBody"
                android:text="@string/privacy_scope_body" />

            <TextView
                style="@style/PrivacyPolicySectionTitle"
                android:text="@string/privacy_handling_title" />

            <TextView
                style="@style/PrivacyPolicySectionBody"
                android:text="@string/privacy_handling_body" />

            <TextView
                style="@style/PrivacyPolicySectionTitle"
                android:text="@string/privacy_access_title" />

            <TextView
                style="@style/PrivacyPolicySectionBody"
                android:text="@string/privacy_access_body" />

            <TextView
                style="@style/PrivacyPolicySectionTitle"
                android:text="@string/privacy_storage_title" />

            <TextView
                style="@style/PrivacyPolicySectionBody"
                android:text="@string/privacy_storage_body" />

            <TextView
                style="@style/PrivacyPolicySectionTitle"
                android:text="@string/privacy_sharing_title" />

            <TextView
                style="@style/PrivacyPolicySectionBody"
                android:text="@string/privacy_sharing_body" />

            <TextView
                style="@style/PrivacyPolicySectionTitle"
                android:text="@string/privacy_changes_title" />

            <TextView
                style="@style/PrivacyPolicySectionBody"
                android:text="@string/privacy_changes_body" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
