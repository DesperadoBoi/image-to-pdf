<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/tool_grid_half_gap"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="top|center_horizontal"
    android:orientation="vertical"
    android:paddingTop="@dimen/tool_item_vertical_padding"
    android:paddingBottom="@dimen/tool_item_vertical_padding">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/tool_icon_area_height">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/image_tool_icon"
            android:layout_width="@dimen/tool_icon_size"
            android:layout_height="@dimen/tool_icon_size"
            android:layout_gravity="center"
            android:importantForAccessibility="no"
            android:scaleType="fitCenter"
            app:tint="@null"
            tools:src="@drawable/ic_tool_image_to_pdf" />

        <TextView
            android:id="@+id/text_tool_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:background="@drawable/bg_tool_badge"
            android:importantForAccessibility="no"
            android:paddingStart="@dimen/tool_badge_horizontal_padding"
            android:paddingTop="@dimen/tool_badge_vertical_padding"
            android:paddingEnd="@dimen/tool_badge_horizontal_padding"
            android:paddingBottom="@dimen/tool_badge_vertical_padding"
            android:text="@string/tool_coming_soon"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:textSize="@dimen/tool_badge_text_size"
            android:textStyle="bold"
            android:visibility="gone"
            tools:visibility="visible" />
    </FrameLayout>

    <TextView
        android:id="@+id/text_tool_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/tool_title_spacing"
        android:ellipsize="end"
        android:breakStrategy="simple"
        android:gravity="top|center_horizontal"
        android:hyphenationFrequency="none"
        android:includeFontPadding="false"
        android:importantForAccessibility="no"
        android:maxLines="2"
        android:textAppearance="?attr/textAppearanceLabelLarge"
        android:textColor="?attr/colorOnSurface"
        tools:text="Изображение в PDF" />

    <TextView
        android:id="@+id/text_tool_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/tool_description_spacing"
        android:breakStrategy="simple"
        android:ellipsize="end"
        android:gravity="top|center_horizontal"
        android:hyphenationFrequency="none"
        android:includeFontPadding="false"
        android:importantForAccessibility="no"
        android:maxLines="1"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:visibility="gone"
        tools:text="Открывайте документы локально"
        tools:visibility="visible" />

</LinearLayout>
